{
  "manifest_version": 3,
  "name": "GarageRoute Bridge",
  "version": "0.1.0",
  "description": "Opt-in bridge that surfaces yard sale listings you see on Facebook Marketplace into your GarageRoute account. Nothing is sent unless you opt in.",
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://www.facebook.com/marketplace/*",
    "https://garageroute.com/*",
    "http://localhost:3000/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "GarageRoute Bridge"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.facebook.com/marketplace/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}