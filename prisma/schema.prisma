generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Sale {
  id          String   @id @default(uuid())
  title       String
  type        String
  address     String
  city        String
  state       String
  zip         String
  lat         Float
  lng         Float
  dates       String
  hours       String
  description String
  seller      String
  verified    Boolean  @default(false)
  photos      String   @default("[]")
  sellerToken       String   @unique @default(uuid())
  sellerUserId      String?
  sellerUser        User?    @relation("SaleToSellerUser", fields: [sellerUserId], references: [id], onDelete: SetNull)
  impactKg          Float    @default(0)
  donationRequested Boolean  @default(false)
  donationStatus    String   @default("")
  donationOrg       String   @default("")
  /// "active" | "ended" | "cancelled". New sales default to active.
  status      String   @default("active")
  /// Set when the sale was cancelled or ended — used for buyer-side messaging.
  statusNote  String   @default("")
  statusChangedAt DateTime?
  // Provenance — "user" (default form), "craigslist", "estatesales", "extension", "facebook", etc.
  source            String        @default("user")
  sourceUrl         String        @default("")
  // TTL — when this listing should auto-end. Cron sweeps past this and sets status='ended'.
  expiresAt         DateTime?
  // The User.id who submitted this listing (for ingested sources, the ingest bot).
  // Distinct from sellerUserId (the on-the-ground host).
  submittedById     String?
  submittedBy       User?         @relation("SaleSubmitter", fields: [submittedById], references: [id], onDelete: SetNull)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  items             Item[]
  queues            Queue[]
  messages          Message[]
  reservations      Reservation[]
  favorites         Favorite[]
  reports           SaleReport[]

  @@index([status, expiresAt])
  @@index([source])
}

/**
 * State — the public state-subdomain network.
 * One row per U.S. state (eventually). Source of truth for
 * subdomain routing, map centroids, and rollout status.
 */
model State {
  id           String    @id @default(uuid())
  slug         String    @unique // e.g. "montana"
  name         String    @unique // e.g. "Montana"
  abbreviation String    @unique // e.g. "MT"
  lat          Float
  lng          Float
  minLat       Float?
  minLng       Float?
  maxLat       Float?
  maxLng       Float?
  status       String    @default("preview") // preview | seeding | live | paused
  launchDate   DateTime?
  tagline      String    @default("")
  heroImage    String    @default("")
  targetCities String    @default("[]") // JSON array of strings
  sortOrder    Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([status, sortOrder])
}

model Item {
  id           String        @id @default(uuid())
  name         String
  category     String
  price        Float?
  condition    String
  photo        String?
  sold         Boolean       @default(false)
  saleId       String
  sale         Sale          @relation(fields: [saleId], references: [id], onDelete: Cascade)
  reservations Reservation[]
}

model Alert {
  id        String   @id @default(uuid())
  email     String
  zip       String
  category  String   @default("")
  radius    Int      @default(25)
  createdAt DateTime @default(now())
}

model Queue {
  id        String   @id @default(uuid())
  saleId    String
  name      String
  email     String
  partySize Int      @default(1)
  status    String   @default("waiting") // waiting, entered, cancelled
  createdAt DateTime @default(now())
  sale      Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
}

model Message {
  id          String   @id @default(uuid())
  saleId      String
  senderName  String
  senderEmail String
  content     String
  createdAt   DateTime @default(now())
  sale        Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
}

model Reservation {
  id              String   @id @default(uuid())
  saleId          String
  itemId          String
  buyerName       String
  buyerEmail      String
  amount          Float
  status          String   @default("pending") // pending, paid, redeemed, refunded
  paymentIntentId String   @default("")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  sale            Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  item            Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(uuid())
  actor     String   @default("admin") // username/identifier performing the action
  action    String // e.g. "sale.verify", "sale.delete", "sale.update"
  entity    String   @default("sale") // "sale" | "user" | "system" | etc
  entityId  String   @default("")
  metadata  String   @default("{}") // JSON blob with extra context
  ip        String   @default("")
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([action])
  @@index([entity, entityId])
}

model User {
  id             String   @id @default(uuid())
  email          String   @unique
  passwordHash   String
  name           String
  city           String   @default("")
  state          String   @default("")
  zip            String   @default("")
  status         String   @default("active") // active | suspended | deleted
  verifiedSeller Boolean  @default(false)
  role           String   @default("user") // user | admin
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

sessions          Session[]
  verifications     UserVerification[]
  sales             Sale[]   @relation("SaleToSellerUser")
  salesSubmitted    Sale[]   @relation("SaleSubmitter")
  passwordResets    PasswordReset[]
  favorites         Favorite[]
  botConversations  BotConversation[]
  savedSearches     SavedSearch[]
  extensionTokens   ExtensionToken[]

  homeLat Float?
  homeLng Float?
  homeZip String?

  @@index([status])
  @@index([verifiedSeller])
}

model Favorite {
  id        String   @id @default(uuid())
  userId    String
  saleId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sale      Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@unique([userId, saleId])
  @@index([userId])
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  ip        String   @default("")
  userAgent String   @default("")
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model UserVerification {
  id            String    @id @default(uuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  status        String    @default("pending") // pending | approved | rejected | superseded
  notes         String    @default("")
  documentUrl   String    @default("") // legacy: external URL
  documentPath  String    @default("") // local storage path, e.g. /uploads/verifications/<uuid>.jpg
  documentName  String    @default("") // original filename
  documentMime  String    @default("") // e.g. image/jpeg
  documentBytes Int       @default(0) // file size in bytes
  submittedAt   DateTime  @default(now())
  reviewedAt    DateTime?
  reviewedBy    String    @default("")

  @@index([status, submittedAt])
  @@index([userId])
}

model PasswordReset {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

/**
 * =============================================================
 * Scout — the GarageRoute marketing + support bot
 * =============================================================
 */

model BotConversation {
  id            String   @id @default(uuid())
  // Channel = "web" | "fb" | "system"
  channel       String   @default("web")
  // External user id (FB PSID, anonymous browser cookie, or User.id)
  externalId    String
  // Optional link to a User (set when verified via magic link)
  userId        String?
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  // Current mode the bot is operating in
  mode          String   @default("marketing") // "marketing" | "support" | "handoff"
  // Last few messages are stored inline for fast rendering.
  // Full history lives in BotMessage.
  context       String   @default("{}") // JSON blob (e.g. {saleId, draftListing})
  // Free-form metadata: zip, source, city, etc.
  metadata      String   @default("{}")
  lastMessageAt DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  messages   BotMessage[]
  leads      Lead[]
  actions    BotAction[]
  magicLinks MagicLink[]

  @@index([channel, externalId])
  @@index([userId])
  @@index([lastMessageAt])
}

model BotMessage {
  id             String   @id @default(uuid())
  conversationId String
  role           String // "user" | "assistant" | "tool" | "system"
  content        String
  // Tool name when role == "tool"
  toolName       String   @default("")
  // Tool call id (for assistant tool_calls / tool results)
  toolCallId     String   @default("")
  createdAt      DateTime @default(now())

  conversation BotConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model Lead {
  id             String   @id @default(uuid())
  conversationId String?
  email          String
  zip            String   @default("")
  wishlist       String   @default("[]") // JSON array of strings
  source         String   @default("web") // web | fb | widget
  status         String   @default("new") // new | contacted | converted | archived
  notes          String   @default("")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  conversation BotConversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([status, createdAt])
}

model BotAction {
  id             String   @id @default(uuid())
  conversationId String
  toolName       String
  args           String   @default("{}") // JSON
  result         String   @default("{}") // JSON
  success        Boolean  @default(true)
  errorMessage   String   @default("")
  createdAt      DateTime @default(now())

  conversation BotConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([toolName])
}

model MagicLink {
  id             String    @id @default(uuid())
  conversationId String
  email          String
  token          String    @unique
  expiresAt      DateTime
  usedAt         DateTime?
  createdAt      DateTime  @default(now())

  conversation BotConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([email])
  @@index([expiresAt])
}

model PendingEmail {
  id        String    @id @default(uuid())
  to        String
  subject   String
  body      String
  // "magic_link" | "lead_welcome" | "handoff_alert" | "support_reply"
  kind      String    @default("generic")
  // Optional related entity ids
  metadata  String    @default("{}")
  // "pending" | "sent" | "failed"
  status    String    @default("pending")
  sentAt    DateTime?
  error     String    @default("")
  createdAt DateTime  @default(now())

  @@index([status, createdAt])
}

/**
 * Dedupe log for buyer notifications (alerts + lead wishlist matches).
 * Ensures the same recipient is never emailed twice about the same sale,
 * even if multiple wishlist keywords match.
 */
model LeadNotificationLog {
  id             String    @id @default(uuid())
  saleId         String
  recipientEmail String
  recipientType  String // "alert" | "lead"
  matchedOn      String    @default("[]") // JSON array of strings
  status         String    @default("pending") // pending | sent | queued | failed
  error          String    @default("")
  sentAt         DateTime?
  createdAt      DateTime  @default(now())

  @@unique([saleId, recipientEmail, recipientType])
  @@index([saleId])
  @@index([recipientEmail])
  @@index([createdAt])
}

/**
 * =============================================================
 * Email inbox — replies to admin@garageroute.com
 * EmailThread groups a conversation. The first inbound message
 * creates the thread. Outbound replies and follow-up inbound mail
 * (matched via In-Reply-To / References / subject) attach here.
 * =============================================================
 */

model EmailThread {
  id            String    @id @default(uuid())
  // Normalized subject (Re:/Fwd: stripped) — used to match follow-ups
  subject       String
  // Primary remote party (the customer)
  fromEmail     String
  fromName      String    @default("")
  // "open" | "closed" | "archived"
  status        String    @default("open")
  // Set when an admin has viewed it — used for unread badges
  lastReadAt    DateTime?
  // Cached for fast list rendering
  lastMessageAt DateTime  @default(now())
  lastSnippet   String    @default("")
  lastDirection String    @default("inbound") // "inbound" | "outbound"
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  messages EmailMessage[]

  @@index([status, lastMessageAt])
  @@index([fromEmail])
}

model EmailMessage {
  id              String    @id @default(uuid())
  threadId        String
  // "inbound" (received from customer) | "outbound" (sent by admin)
  direction       String
  fromAddress     String
  fromName        String    @default("")
  toAddress       String
  toName          String    @default("")
  subject         String
  bodyText        String    @default("")
  bodyHtml        String    @default("")
  // Resend's message id for outbound (used to thread via In-Reply-To)
  resendMessageId String    @default("")
  // The original message's Message-ID header (inbound) or our own (outbound)
  messageId       String    @default("")
  inReplyTo       String    @default("")
  references      String    @default("")
  // "received" | "sent" | "delivered" | "bounced" | "failed"
  status          String    @default("received")
  error           String    @default("")
  // Provider metadata (delivery events, opens, etc.) — JSON
  providerMeta    String    @default("{}")
  receivedAt      DateTime?
  sentAt          DateTime?
  createdAt       DateTime  @default(now())

  thread EmailThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
  @@index([resendMessageId])
  @@index([messageId])
}

/**
 * =============================================================
 * SavedSearch — user- or email-bound alert subscriptions
 * attached to a specific (zip, category, radius) tuple.
 * Auth-optional:
 * - signed-in users: userId set, email optional (used as contact)
 * - anonymous: userId null, email required
 * Dedupe for outbound notifications reuses LeadNotificationLog
 * (recipientType = "saved_search"). This keeps the dedupe table
 * the single source of truth across alert/lead/saved_search.
 * =============================================================
 */
model SavedSearch {
  id        String   @id @default(uuid())
  // User-owned (signed in). Null when the alert is email-only.
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Required for anonymous signups. Lower-cased at the call site.
  email     String
  // The search tuple we alert on.
  zip       String
  category  String   @default("")
  radius    Int      @default(25)
  // Audit
  createdAt DateTime @default(now())
  active    Boolean  @default(true)

  @@index([zip, category])
  @@index([userId])
  @@index([email])
}

/**
 * =============================================================
 * SellerDigestRun — audit + idempotency log for the daily seller
 * digest cron. One row per cron execution.
 * =============================================================
 */
model SellerDigestRun {
  id             String   @id @default(uuid())
  sentAt         DateTime @default(now())
  recipientCount Int      @default(0)
  // "ok" | "partial" | "failed"
  status         String   @default("ok")
  error          String   @default("")

  @@index([sentAt])
}

/**
 * =============================================================
 * ReservationAccessToken — short-lived signed token that lets a
 * buyer (who may be anonymous) view + manage their reservation
 * via the email "magic link".
 * Issued when the seller marks the reservation "paid" and embedded
 * in the buyer confirmation email. Single-use semantics: a second
 * click after usedAt is set shows the read-only view.
 * =============================================================
 */
model ReservationAccessToken {
  id            String    @id @default(uuid())
  reservationId String    @unique
  token         String    @unique
  expiresAt     DateTime
  usedAt        DateTime?
  createdAt     DateTime  @default(now())

  @@index([token])
  @@index([expiresAt])
}

/**
 * =============================================================
 * SaleReport — buyer-driven abuse/spam reports on a listing.
 * Public endpoint (anyone with an email can report), admin-only
 * moderation queue. Status workflow:
 * pending -> reviewed -> actioned (sale removed) | dismissed
 * =============================================================
 */
model SaleReport {
  id            String    @id @default(uuid())
  saleId        String
  sale          Sale      @relation(fields: [saleId], references: [id], onDelete: Cascade)
  // Reporter — email required so we can follow up. Never shown publicly.
  reporterEmail String
  // "spam" | "duplicate" | "scam" | "already_over" | "wrong_address" | "inappropriate" | "other"
  reason        String
  // Free-text context from the reporter (max 1000 chars)
  notes         String    @default("")
  // "pending" | "reviewed" | "actioned" | "dismissed"
  status        String    @default("pending")
  // Set when an admin acts on it.
  reviewedAt    DateTime?
  reviewedBy    String    @default("") // admin username
  // Same email can't file the same reason against the same sale twice in 24h.
  // Enforced at the API layer using createdAt + saleId+email+reason.
  createdAt     DateTime  @default(now())

  @@index([saleId, createdAt])
  @@index([status, createdAt])
}

/**
 * =============================================================
 * IngestSource — registered external data feed that contributes
 * listings (Craigslist RSS, EstateSales.NET, municipal calendars,
 * FB Marketplace via opt-in extension). One row per source so we
 * can dedupe by external id and surface source health in admin.
 * =============================================================
 */
model IngestSource {
  id            String    @id @default(uuid())
  // "craigslist" | "estatesales" | "municipal" | "extension" | "facebook_marketplace" | "newspaper"
  kind          String
  // Free-form slug identifying the specific feed (city for CL, region for municipal, etc.)
  slug          String
  // Human label for admin UI.
  label         String
  // Base URL of the feed (RSS endpoint, scrape origin, etc.)
  baseUrl       String
  // Per-source config JSON (zip filters, category filters, lookback hours, etc.)
  config        String    @default("{}")
  // "active" | "paused" | "error"
  status        String    @default("active")
  // Bookkeeping.
  lastRunAt     DateTime?
  lastError     String    @default("")
  // Counts since last successful run.
  lastSeenCount Int       @default(0)
  lastNewCount  Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([kind, slug])
  @@index([status, lastRunAt])
}

/**
 * =============================================================
 * IngestItem — raw payloads we ingested, kept for audit / re-derivation.
 * One row per external listing we ever ingested (even duplicates).
 * Dedupe to Sale happens via IngestItem.saleId once mapped.
 * =============================================================
 */
model IngestItem {
  id         String   @id @default(uuid())
  sourceId   String
  // External id from the source — CL post id, ESNET listing id, FB item id, etc.
  externalId String
  // Raw payload (JSON) for debugging + replay. Keep small.
  payload    String   @default("{}")
  // "ok" | "skipped_duplicate" | "skipped_filter" | "skipped_too_old" | "error"
  status     String   @default("ok")
  // Set when mapped to a Sale row.
  saleId     String?
  error      String   @default("")
  fetchedAt  DateTime @default(now())

  @@unique([sourceId, externalId])
  @@index([sourceId, fetchedAt])
  @@index([status, fetchedAt])
}

/* =============================================================
 * ExtensionToken — bearer token issued to the GarageRoute Bridge
 * Chrome extension. Hashed at rest (sha256), expires after 90 days,
 * revocable from /connect-extension. One user can have multiple tokens
 * (e.g. one per device/browser).
 * ============================================================= */
model ExtensionToken {
  id         String    @id @default(uuid())
  userId     String
  // sha256(token) — we never store the plaintext after creation.
  tokenHash  String    @unique
  // Human label so users recognize the device ("MacBook Chrome", "Work laptop").
  label      String    @default("")
  userAgent  String    @default("")
  // Geography hint the extension claims (zip + city). Used to scope ingest.
  scopeZip   String    @default("")
  scopeCity  String    @default("")
  scopeState String    @default("")
  createdAt  DateTime  @default(now())
  expiresAt  DateTime
  revokedAt  DateTime?
  lastUsedAt DateTime?

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}
